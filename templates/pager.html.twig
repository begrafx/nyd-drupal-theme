{#
/**
 * @file
 * NydCSS Theme — pager.html.twig
 *
 * Variables:
 *   - heading_id: Accessible heading ID for the pager.
 *   - items.previous, items.next, items.first, items.last: Pager links.
 *   - items.pages: Array of page links.
 *   - current: Current page number.
 */
#}

{% if items %}
  <nav class="pager" aria-labelledby="{{ heading_id }}" role="navigation">
    <h4 id="{{ heading_id }}" class="visually-hidden">{{ 'Pagination'|t }}</h4>
    <ul class="pager__items">

      {# First page #}
      {% if items.first %}
        <li class="pager__item pager__item--first">
          <a href="{{ items.first.href }}" title="{{ 'Go to first page'|t }}"
             {{ items.first.attributes }}>
            <span aria-hidden="true">«</span>
            <span class="visually-hidden">{{ 'First page'|t }}</span>
          </a>
        </li>
      {% endif %}

      {# Previous page #}
      {% if items.previous %}
        <li class="pager__item pager__item--previous">
          <a href="{{ items.previous.href }}" title="{{ 'Go to previous page'|t }}" rel="prev"
             {{ items.previous.attributes }}>
            <span aria-hidden="true">‹</span>
            <span class="visually-hidden">{{ 'Previous page'|t }}</span>
          </a>
        </li>
      {% endif %}

      {# Page numbers #}
      {% for key, item in items.pages %}
        <li class="pager__item{{ current == key ? ' is-active' : '' }}">
          {% if current == key %}
            <span aria-current="page" aria-label="{{ 'Page @num'|t({'@num': key}) }}">{{ key }}</span>
          {% else %}
            <a href="{{ item.href }}" aria-label="{{ 'Page @num'|t({'@num': key}) }}"
               {{ item.attributes }}>{{ key }}</a>
          {% endif %}
        </li>
      {% endfor %}

      {# Next page #}
      {% if items.next %}
        <li class="pager__item pager__item--next">
          <a href="{{ items.next.href }}" title="{{ 'Go to next page'|t }}" rel="next"
             {{ items.next.attributes }}>
            <span aria-hidden="true">›</span>
            <span class="visually-hidden">{{ 'Next page'|t }}</span>
          </a>
        </li>
      {% endif %}

      {# Last page #}
      {% if items.last %}
        <li class="pager__item pager__item--last">
          <a href="{{ items.last.href }}" title="{{ 'Go to last page'|t }}"
             {{ items.last.attributes }}>
            <span aria-hidden="true">»</span>
            <span class="visually-hidden">{{ 'Last page'|t }}</span>
          </a>
        </li>
      {% endif %}

    </ul>
  </nav>
{% endif %}
